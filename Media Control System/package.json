{
  "name": "media-control-agent",
  "version": "1.0.0",
  "description": "Comprehensive media control agent system for n8n workflow automation",
  "main": "complete_integration_test.js",
  "scripts": {
    "start": "node complete_integration_test.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "dev": "nodemon complete_integration_test.js",
    "docker:build": "docker build -t media-control-agent .",
    "docker:run": "docker run -p 3000:3000 --env-file .env media-control-agent"
  },
  "keywords": [
    "n8n",
    "automation",
    "chatbot",
    "voice-bot",
    "media-control",
    "workflow"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "sanitize-html": "^2.11.0",
    "uuid": "^9.0.1",
    "validator": "^13.11.0",
    "vm2": "^3.9.19",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "**/*.js",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/tests/**"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
