    {
      "parameters": {
        "jsCode": "// Secure Script Validation\nconst input = $input.all()[0].json;\nconst scriptContent = input.scriptContent || '';\n\n// Security patterns to detect\nconst dangerousPatterns = [\n  /\\beval\\s*\\(/i,\n  /\\bFunction\\s*\\(/i,\n  /\\brequire\\s*\\(\\s*['\"]fs['\"]/i,\n  /\\brequire\\s*\\(\\s*['\"]child_process['\"]/i,\n  /\\bprocess\\.env/i,\n  /\\bdocument\\.cookie/i\n];\n\nconst securityIssues = [];\n\nfor (const pattern of dangerousPatterns) {\n  if (pattern.test(scriptContent)) {\n    securityIssues.push(`Dangerous pattern detected: ${pattern.source}`);\n  }\n}\n\n// Size check\nconst maxSize = 102400; // 100KB\nif (scriptContent.length > maxSize) {\n  securityIssues.push(`Script exceeds size limit (${scriptContent.length} > ${maxSize})`);\n}\n\nconst scriptValidation = {\n  passed: securityIssues.length === 0,\n  issues: securityIssues,\n  timestamp: new Date().toISOString()\n};\n\nreturn { json: { ...input, scriptValidation };"}
      },
