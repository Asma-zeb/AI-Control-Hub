      "parameters": {
        "jsCode": "// Security Alert Logging\nconst errorData = $input.all()[0].json;\n\n// Log security event (integrate with your SIEM)\nconst securityAlert = {\n  type: 'WORKFLOW_ERROR',\n  severity: 'high',\n  timestamp: new Date().toISOString(),\n  details: {\n    errorCode: errorData.error_code,\n    agentId: errorData.agentId,\n    clientId: errorData.clientId\n  },\n  action: errorData.recommended_action\n};\n\n// In production, send to your security monitoring system\nconsole.log('SECURITY ALERT:', JSON.stringify(securityAlert));\n\nreturn { json: { ...errorData, securityAlert };"}
