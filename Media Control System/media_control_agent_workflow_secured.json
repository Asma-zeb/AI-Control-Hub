    {
      "parameters": {
        "jsCode": "// Secure Data Recording with PII handling\nconst input = $input.all()[0].json;\n\n// Mask sensitive data for logging\nfunction maskPII(data) {\n  const masked = { ...data };\n  \n  if (masked.userDetails) {\n    if (masked.userDetails.email) {\n      masked.userDetails.email = masked.userDetails.email.replace(\n        /(.{2}).*(@.*)/,\n        '$1***$2'\n      );\n    }\n    if (masked.userDetails.phone) {\n      masked.userDetails.phone = masked.userDetails.phone.replace(\n        /(.{3}).*(.{3})/,\n        '$1***$2'\n      );\n    }\n  }\n  \n  return masked;\n}\n\n// Record interaction (with masked data for logs)\nconst recordedData = {\n  timestamp: new Date().toISOString(),\n  agentId: input.agentId,\n  clientId: input.clientId,\n  channel: input.isCall ? 'call' : 'chat',\n  healthStatus: input.health?.status,\n  // Full data stored securely, masked data for logs\n  logData: maskPII(input)\n};\n\nreturn { json: { ...input, recordedData };"}
      },
      "id": "data-recorder",
      "name": "Data Recorder",
      "type": "n8n-nodes-base.code",
