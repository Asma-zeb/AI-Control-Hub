      "parameters": {
        "jsCode": "// Input Validation and Sanitization\nconst input = $input.all()[0].json;\n\n// Validate required fields\nconst requiredFields = ['agentId', 'clientId', 'configValid'];\nfor (const field of requiredFields) {\n  if (!input[field]) {\n    throw new Error(`Missing required field: ${field}`);\n  }\n}\n\n// Sanitize string inputs (prevent XSS/injection)\nfunction sanitize(str) {\n  if (typeof str !== 'string') return str;\n  return str\n    .replace(/[<>]/g, '')\n    .replace(/javascript:/gi, '')\n    .replace(/on\\w+=/gi, '')\n    .trim();\n}\n\n// Apply sanitization\nconst sanitized = {\n  ...input,\n  agentId: sanitize(input.agentId),\n  clientId: sanitize(input.clientId),\n  jobSector: input.jobSector ? sanitize(input.jobSector) : null,\n  notes: input.notes ? sanitize(input.notes) : null\n};\n\n// Validate configValid is boolean\nif (typeof sanitized.configValid !== 'boolean') {\n  sanitized.configValid = sanitized.configValid === 'true';\n}\n\n// Rate limiting check (simple in-memory)\nconst rateLimitKey = `rate_${sanitized.clientId}`;\nconst now = Date.now();\nconst rateWindow = 60000; // 1 minute\nconst maxRequests = 30;\n\nif (!global.rateLimit) global.rateLimit = {};\nif (!global.rateLimit[rateLimitKey]) {\n  global.rateLimit[rateLimitKey] = [];\n}\n\nglobal.rateLimit[rateLimitKey] = global.rateLimit[rateLimitKey].filter(\n  ts => now - ts < rateWindow\n);\n\nif (global.rateLimit[rateLimitKey].length >= maxRequests) {\n  throw new Error('Rate limit exceeded. Please slow down.');\n}\n\nglobal.rateLimit[rateLimitKey].push(now);\n\nreturn { json: sanitized };"}
      },
