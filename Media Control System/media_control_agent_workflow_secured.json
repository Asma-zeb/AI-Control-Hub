        "jsCode": "// Agent Health Check with timeout\nconst agentId = $input.all()[0].json.agentId;\n\n// Simulate health check (replace with actual API call)\nconst healthStatus = {\n  agentId,\n  healthy: true,\n  responseTime: Math.floor(Math.random() * 100) + 50,\n  lastHeartbeat: new Date().toISOString(),\n  status: 'operational'\n};\n\n// Check for stuck agents (no response > 5 seconds)\nif (healthStatus.responseTime > 5000) {\n  healthStatus.healthy = false;\n  healthStatus.status = 'degraded';\n}\n\nreturn { json: { ...$input.all()[0].json, health: healthStatus };"}
